{
  "name": "@ddunigma/node",
  "version": "2.1.1",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "bench": "node --expose-gc --import tsx benchmarks/encoding-benchmark.ts",
    "pack:check": "node scripts/verify-pack.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src benchmarks eslint.config.mjs tsup.config.ts --fix",
    "format": "prettier --write src/",
    "test:all": "vitest run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/parkjh2568/ddunigma-node.git"
  },
  "author": "",
  "license": "BSD-2-Clause",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "ddu",
    "enigma",
    "Base64",
    "base conversion",
    "base64 encode",
    "base64 decode",
    "base64_encode",
    "base64_decode",
    "encode",
    "decode"
  ]
}
